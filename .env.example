# Server Configuration
NODE_ENV=development
PORT=3020
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/flora-mercury

# JWT Authentication (must match main Flora app)
JWT_SECRET=your-jwt-secret-here

# Mercury API Configuration
MERCURY_API_KEY=your-mercury-api-key-here
MERCURY_API_URL=https://api.mercury.com/api/v1

# Encryption Key (32 bytes in hex format for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-here

# Mock Mode (set to 'true' for development without API credentials)
MOCK_MODE=true

# Service URLs
SERVICE_URL=http://localhost:3020
FRONTEND_URL=http://localhost:3000
